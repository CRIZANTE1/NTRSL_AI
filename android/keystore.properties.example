# Copie este arquivo para android/keystore.properties (SEM o .example)
# e preencha com os valores reais do seu keystore.
#
# IMPORTANTE: NUNCA commite keystore.properties nem o arquivo .jks no git.
# Ambos já estão no android/.gitignore.
#
# Como criar o keystore:
#   Android Studio → Build → Generate Signed Bundle / APK
#   → Create new keystore…
#   → Salve como: android/keystore/ntrsl-release.jks

storeFile=../keystore/ntrsl-release.jks
storePassword=DIGITE_A_SENHA_DO_KEYSTORE
keyAlias=ntrsl-key
keyPassword=DIGITE_A_SENHA_DA_CHAVE
