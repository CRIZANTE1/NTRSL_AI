# Copie para .env.local e preencha os valores.
# Apenas variáveis VITE_* listadas aqui pertencem ao app React.

VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# Opcional: habilitar push nativo (FCM)
# VITE_ENABLE_PUSH=true

# ---------------------------------------------------------------------------
# GEMINI — NÃO coloque chave no .env.local do app
# ---------------------------------------------------------------------------
# A IA roda nas Edge Functions do Supabase. Configure no Dashboard:
#   Project Settings → Edge Functions → Secrets → GOOGLE_API_KEY
#
# Guia completo: docs/GEMINI_SECRETS.md
#
# Modelo padrão (Edge Functions, servidor): gemini-3.1-flash-lite
# Override opcional no Supabase: GEMINI_MODEL=gemini-3.1-flash-lite
#
# ❌ NÃO use VITE_GEMINI_API_KEY (vaza no bundle JavaScript / APK)
# ✅ Use GOOGLE_API_KEY somente nos secrets do Supabase
#
# USDA FoodData Central (busca de alimentos via Edge Function food-search):
#   Project Settings → Edge Functions → Secrets → FDC_API_KEY
#   Obtenha em: https://fdc.nal.usda.gov/api-key-signup
#
# ❌ NÃO use VITE_FDC_API_KEY no app
#
# WGER (busca de exercícios via Edge Function exercise-search):
#   Project Settings → Edge Functions → Secrets → WEGER_API_KEY
#   Obtenha em: https://wger.de/user/api-key (token permanente do perfil)
#
# ❌ NÃO use VITE_WGER_API_KEY no app
