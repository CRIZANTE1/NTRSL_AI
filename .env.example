# Copie para .env.local e preencha os valores.

VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# Opcional: habilitar push nativo (FCM)
# VITE_ENABLE_PUSH=true

# Secrets das Edge Functions — configurar NO SUPABASE (não no .env.local do app):
# Dashboard → Project Settings → Edge Functions → Secrets
# GOOGLE_API_KEY=<gemini-api-key>
# GEMINI_MODEL=gemini-2.5-flash  (opcional)
#
# Não use VITE_GEMINI_API_KEY no cliente — a chave fica só no servidor.
